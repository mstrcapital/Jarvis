{
  "version": "1.0",
  "lastUpdated": "2026-02-15",
  "author": "Jarvis",
  
  "config": {
    "baseDir": "/root/.openclaw/workspace/video-materials",
    "素材目录": "素材",
    "日志目录": "日志",
    "工具目录": "tools",
    
    "日期格式": "YYYYMMDD",
    "时间格式": "HHMMSS"
  },
  
  "分类": {
    "迪拜-阿布扎比": {
      "优先级": "高",
      "目标数量": 20,
      "说明": "城市风光、地标建筑、文化活动"
    },
    "土豪日常": {
      "优先级": "高",
      "目标数量": 15,
      "说明": "超跑、豪宅、奢华生活"
    },
    "华人群体": {
      "优先级": "中",
      "目标数量": 10,
      "说明": "华人故事、华人生活"
    },
    "生活定居": {
      "优先级": "中",
      "目标数量": 10,
      "说明": "签证、房产、教育、医疗"
    },
    "高清街拍": {
      "优先级": "中",
      "目标数量": 15,
      "说明": "城市街拍、建筑摄影"
    }
  },
  
  "平台配置": {
    "Instagram": {
      "工具": ["4K Stogram", "Instaloader"],
      "下载地址": "https://www.4kdownload.com/products/product-stogram",
      "备用工具": "https://github.com/instaloader/instaloader"
    },
    "TikTok": {
      "工具": ["SSSTik", "TikMate", "yt-dlp"],
      "下载地址": "https://ssstik.io",
      "备用地址": "https://www.tikmate.io"
    },
    "YouTube": {
      "工具": ["4K Video Downloader", "yt-dlp"],
      "下载地址": "https://www.4kdownload.com/products/video-downloader",
      "命令行安装": "pip install yt-dlp"
    },
    "Twitter/X": {
      "工具": ["Twitter Video Downloader", "yt-dlp"],
      "下载地址": "https://twdownloader.com",
      "备用地址": "https://ssstwitter.com"
    }
  },
  
  "素材规格": {
    "视频": {
      "分辨率": "1080P以上",
      "时长": "15-60秒",
      "格式": "MP4",
      "帧率": "30fps以上"
    },
    "图片": {
      "封面": {
        "尺寸": "1080x1920",
        "比例": "9:16"
      },
      "配图": {
        "尺寸": "1920x1080",
        "比例": "16:9 或 1:1"
      }
    }
  },
  
  "命名规范": {
    "格式": "[分类]_[日期]_[来源]_[描述].[扩展名]",
    "示例": "迪拜风光_20260215_@dubai_哈利法塔日落.mp4",
    "来源标识": {
      "IG": "Instagram",
      "TT": "TikTok",
      "YT": "YouTube",
      "TW": "Twitter/X",
      "UB": "Unsplash/Pexels"
    }
  },
  
  "版权等级": {
    "可用": {
      "标识": "✅",
      "颜色": "绿色",
      "说明": "无水印/已授权"
    },
    "需标注": {
      "标识": "⚠️",
      "颜色": "黄色",
      "说明": "可商用但需注明来源"
    },
    "待确认": {
      "标识": "❌",
      "颜色": "红色",
      "说明": "需联系作者确认"
    }
  },
  
  "每日任务": {
    "早间": {
      "时间": "08:00 GMT+8",
      "任务": ["Instagram刷新", "TikTok热门"],
      "目标": "10条视频/图片"
    },
    "午间": {
      "时间": "12:00 GMT+8",
      "任务": ["TikTok热门", "YouTube更新"],
      "目标": "15条视频"
    },
    "晚间": {
      "时间": "20:00 GMT+8",
      "任务": ["素材整理", "版权检查", "归档"],
      "目标": "完成当日收集"
    }
  },
  
  "发布计划": {
    "每日发布": {
      "视频号": "1-2条短视频",
      "小红书": "1篇图文",
      "抖音": "1条视频"
    },
    "每周节奏": {
      "周一": "攻略",
      "周二": "土豪",
      "周三": "华人",
      "周四": "街拍",
      "周五": "风情",
      "周六": "休息",
      "周日": "预告"
    }
  },
  
  "追踪指标": {
    "视频号": ["播放量", "点赞", "分享", "完播率"],
    "小红书": ["阅读", "点赞", "收藏", "评论"],
    "抖音": ["播放", "点赞", "评论", "转化"]
  }
}
